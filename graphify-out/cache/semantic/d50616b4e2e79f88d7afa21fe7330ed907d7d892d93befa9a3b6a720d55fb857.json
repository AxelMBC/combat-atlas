{"nodes": [{"id": "openspec_changes_archive_2026_06_26_hero_native_fullscreen_design_hero_fullscreen", "label": "Hero Native Fullscreen Design", "file_type": "document", "source_file": "openspec/changes/archive/2026-06-26-hero-native-fullscreen/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "openspec_changes_archive_2026_06_26_hero_native_fullscreen_design_usehertofullscreen", "label": "useHeroFullscreen Hook", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-26-hero-native-fullscreen/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Orientation lock/unlock kept inside useHeroFullscreen because the hook already owns enter/exit and the fullscreenchange listener; lock only succeeds inside a fullscreen context so sequencing matters. A CSS transform:rotate(90deg) portrait hack was rejected because it breaks pointer/scroll coordinates and YouTube controls. Unlock is driven from the fullscreenchange sync so Esc/gesture exits also release the lock."}, {"id": "openspec_changes_archive_2026_06_26_hero_native_fullscreen_design_screen_orientation_api", "label": "Screen Orientation API", "file_type": "concept", "source_file": "openspec/changes/archive/2026-06-26-hero-native-fullscreen/design.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Feature-detected (screen.orientation with lock method) and failures swallowed via .catch; iOS Safari and desktop reject the lock, which is benign. No CSS fake-fullscreen fallback for iOS (out of scope)."}], "edges": [{"source": "openspec_changes_archive_2026_06_26_hero_native_fullscreen_design_hero_fullscreen", "target": "openspec_changes_archive_2026_06_26_hero_native_fullscreen_design_usehertofullscreen", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-26-hero-native-fullscreen/design.md", "source_location": null, "weight": 1.0}, {"source": "openspec_changes_archive_2026_06_26_hero_native_fullscreen_design_usehertofullscreen", "target": "openspec_changes_archive_2026_06_26_hero_native_fullscreen_design_screen_orientation_api", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-26-hero-native-fullscreen/design.md", "source_location": null, "weight": 1.0}, {"source": "openspec_changes_archive_2026_06_26_hero_native_fullscreen_design_usehertofullscreen", "target": "docs_specs_cinematichero", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-26-hero-native-fullscreen/design.md", "source_location": null, "weight": 1.0}, {"source": "openspec_changes_archive_2026_06_26_hero_native_fullscreen_design_screen_orientation_api", "target": "openspec_changes_archive_2026_06_26_mobile_scroll_focus_cards_design_intersectionobserver", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.7, "source_file": "openspec/changes/archive/2026-06-26-hero-native-fullscreen/design.md", "source_location": null, "weight": 1.0}], "hyperedges": []}