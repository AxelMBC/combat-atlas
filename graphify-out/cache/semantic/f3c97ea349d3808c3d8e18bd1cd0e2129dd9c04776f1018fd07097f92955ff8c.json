{"nodes": [{"id": "openspec_changes_archive_2026_06_26_mobile_scroll_focus_cards_proposal_scroll_focus_cards", "label": "Mobile Scroll-Focus Cards Proposal", "file_type": "document", "source_file": "openspec/changes/archive/2026-06-26-mobile-scroll-focus-cards/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "openspec_changes_archive_2026_06_26_mobile_scroll_focus_cards_proposal_usescrollfocus", "label": "useScrollFocus Hook", "file_type": "rationale", "source_file": "openspec/changes/archive/2026-06-26-mobile-scroll-focus-cards/proposal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reports whether an element is centered using an IntersectionObserver with rootMargin '-47% 0px -47% 0px'. Chosen over a scroll listener + distance math (intersection is computed off the main thread, no per-frame cost) and over CSS animation-timeline:view() (unreliable iOS Safari support as of 2026). No-op on hover-capable pointers via matchMedia('(hover: none)'). Band -47% kept above the 24px gutter to avoid 'nothing highlighted' flicker."}], "edges": [{"source": "openspec_changes_archive_2026_06_26_mobile_scroll_focus_cards_proposal_scroll_focus_cards", "target": "openspec_changes_archive_2026_06_26_mobile_scroll_focus_cards_proposal_usescrollfocus", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-26-mobile-scroll-focus-cards/proposal.md", "source_location": null, "weight": 1.0}, {"source": "openspec_changes_archive_2026_06_26_mobile_scroll_focus_cards_proposal_usescrollfocus", "target": "openspec_specs_scroll_focus_cards_spec_fightcard", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "openspec/changes/archive/2026-06-26-mobile-scroll-focus-cards/proposal.md", "source_location": null, "weight": 1.0}, {"source": "op